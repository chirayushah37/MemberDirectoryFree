<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="FastCgiModule"
           scriptProcessor="C:\Users\Administrator\AppData\Local\Programs\Python\Python313\python.exe|C:\Users\Administrator\AppData\Local\Programs\Python\Python313\Lib\site-packages\wfastcgi.py"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>
  </system.webServer>

  <appSettings>
    <add key="WSGI_HANDLER" value="app.app" />
    <add key="PYTHONPATH" value="C:\Windows\System64\Hostingspace\shreealkapurijainsangh.com" />
    <add key="WSGI_LOG" value="C:\Windows\System64\Hostingspace\shreealkapurijainsangh.com\log.txt" />
	<add key="TURBO_SMTP_CONSUMER_KEY" value="9c317bfb19cb9adb9a85" />
	<add key="TURBO_SMTP_CONSUMER_SECRET" value="e3lCbcWjURHvBifkJ16m" />
	<add key="TURBO_SMTP_FROM" value="ajs@chirayusoft.com" />	
	
  </appSettings>
  
</configuration>